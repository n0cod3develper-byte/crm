# =============================================================
# CARGAR CRM — Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA comitear el archivo .env al repositorio
# =============================================================

# Base de Datos
DB_PASSWORD=crm_dev_password

# JWT
JWT_SECRET=cambiar_por_secreto_seguro_min_32_caracteres
JWT_REFRESH_SECRET=cambiar_por_refresh_secreto_seguro_min_32_caracteres

# Google OAuth
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
# Obtener en: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# OpenAI
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# WhatsApp Business (Meta)
# Obtener en: https://developers.facebook.com/apps
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=cargar_crm_whatsapp_verify

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@cargarsas.com
EMAIL_FROM_NAME=CARGAR SAS CRM

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_123
S3_BUCKET=crm-files

# Asterisk (desactivado por defecto)
ASTERISK_ENABLED=false
ASTERISK_AMI_HOST=192.168.1.100
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=crm_user
ASTERISK_AMI_SECRET=
ASTERISK_ARI_URL=http://192.168.1.100:8088
ASTERISK_ARI_USER=
ASTERISK_ARI_PASSWORD=
ASTERISK_RECORDING_SYNC_INTERVAL=300

# Frontend URL (para CORS y OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# Sentry (opcional en desarrollo)
SENTRY_DSN=
