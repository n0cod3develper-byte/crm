# ─── BACKEND CONFIG ──────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cargar_crm

# Clerk (Backend)
# Consigue estas llaves en https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Cache (Segundos)
PERMISSIONS_CACHE_TTL=3600

# ─── FRONTEND CONFIG ─────────────────────────────────────────
# (Ubicado habitualmente en frontend/.env)
VITE_API_URL=http://localhost:4000/api/v1
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
