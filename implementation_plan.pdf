### 6.5 Integración de IA (OpenAI GPT-4o)

```javascript
// src/modules/ai/ai.service.js
export async function generatePipelineSuggestions(userId) {
  const opportunities = await getStaleOpportunities(userId); // > 14 días sin actividad
  
  const prompt = `Eres un consultor de ventas especializado en logística.
Analiza estas oportunidades estancadas y sugiere acciones concretas:
${JSON.stringify(opportunities.map(o => ({
  empresa: o.company_name,
  etapa: o.stage_name,
  valor: o.value,
  diasSinContacto: o.days_since_contact,
  ultimaComunicacion: o.last_communication_summary
})))}

Por cada oportunidad responde en JSON con: 
{ id, sugerencia, accionRecomendada, urgencia: 'alta'|'media'|'baja' }`;

  const completion = await openai.chat.completions.create({
    model: 'gpt-4o',
    messages: [{ role: 'user', content: prompt }],
    response_format: { type: 'json_object' },
    max_tokens: 1000
  });

  // Cachea resultado 4 horas en Redis para no consumir tokens repetidamente
  await redis.setex(`ai:pipeline:${userId}`, 14400, completion.choices[0].message.content);
  return JSON.parse(completion.choices[0].message.content);
}
```

### 6.6 Integración Asterisk (Central Telefónica AMI/ARI)

> **Estrategia:** La integración se diseña desde v1 como un módulo desactivado por feature flag (`ASTERISK_ENABLED=false`). Cuando el cliente active su central Asterisk, solo se requiere configurar las credenciales AMI/ARI y el flag — sin necesidad de refactoring.

#### Arquitectura de la Integración

```
┌─────────────────┐      AMI (TCP 5038)     ┌──────────────────┐
│  Backend Node.js │ ◄──────────────────────► │  Asterisk PBX    │
│  AmiClient.js    │                          │  (servidor LAN)  │
│                  │  ARI REST (HTTP 8088)   │                  │
│  AriClient.js    │ ◄──────────────────────► │  /ari/...        │
└────────┬─────────┘                          └──────────────────┘
         │ BullMQ job                                  │
         │ 'process-ami-event'                         │ grabaciones WAV
┌────────▼─────────┐                          ┌────────▼─────────┐
│  asterisk.worker  │                         │  S3/MinIO        │
│  - screen pop     │  WebSocket al frontend  │  (sync periódica)│
│  - registra CDR   │ ─────────────────────►  │                  │
│  - vincula contacto                         └──────────────────┘
└──────────────────┘
```

#### Click-to-Call (AMI Originate)

```javascript
// src/adapters/asterisk/AmiClient.js
import AmiIo from 'asterisk-ami'; // npm: asterisk-ami

export class AmiClient {
  constructor(config) {
    this.ami = new AmiIo({
      host: config.ami_host,
      port: config.ami_port,
      login: config.ami_user,
      password: config.ami_secret,
      reconnect: true,           // reconexión automática
      reconnectTimeout: 5000,
    });
    this._setupEventListeners();
  }

  // Click-to-call: origina llamada desde la extensión del agente
  async clickToCall({ agentExtension, destinationNumber, contactId, opportunityId, userId }) {
    return new Promise((resolve, reject) => {
      const actionId = `ctc-${Date.now()}`;
      this.ami.action({
        Action:   'Originate',
        ActionID:  actionId,
        Channel:  `PJSIP/${agentExtension}`,   // extensión del agente
        Exten:     destinationNumber,           // número del cliente
        Context:  'from-internal',
        Priority:  1,
        CallerID: `CARGAR SAS <${agentExtension}>`,
        Timeout:   30000,                       // 30 segundos espera
        Variable: [
          `CRM_CONTACT_ID=${contactId}`,
          `CRM_OPPORTUNITY_ID=${opportunityId ?? ''}`,
          `CRM_USER_ID=${userId}`,
        ].join(','),
        Async: 'true',
      }, (err, res) => {
        if (err) return reject(err);
        resolve(res);
      });
    });
  }

  // Escucha eventos y los encola en BullMQ para procesamiento asíncrono
  _setupEventListeners() {
    this.ami.on('event', async (event) => {
      if (['Hangup', 'CDR', 'VarSet'].includes(event.event)) {
        await asteriskQueue.add('process-ami-event', { event });
      }
    });
  }
}
```

#### Screen Pop al Agente

```javascript
// src/workers/asterisk.worker.js
asteriskQueue.process('process-ami-event', async (job) => {
  const { event } = job.data;

  if (event.event === 'Newchannel' && event.context === 'from-trunk') {
    // Llamada ENTRANTE: buscar contacto por número
    const callerNumber = normalizeE164(event.calleridnum);
    const contact = await findContactByPhone(callerNumber);

    if (contact) {
      // Screen Pop: notificar al agente via WebSocket
      const agentExtension = event.exten;
      const userId = await getUserIdByExtension(agentExtension);

      if (userId) {
        websocketServer.notifyUser(userId, {
          type:    'SCREEN_POP',
          payload: {
            contact,
            callerNumber,
            asteriskChannel: event.channel,
            linkedOpportunities: await getOpenOpportunities(contact.id),
          }
        });
      }
    }
  }

  if (event.event === 'Hangup') {
    // Registrar CDR automáticamente en communications
    const crmVars = parseCrmVariables(event);
    await callRecordsService.createFromHangup(event, crmVars);
  }
});
```

#### Sincronización de Grabaciones a S3

```javascript
// src/workers/asterisk.worker.js — job programado cada 5 minutos
ascterikQueue.process('sync-recordings', async (job) => {
  const pendingRecordings = await db.query(`
    SELECT id, recording_filename FROM call_records
    WHERE recording_filename IS NOT NULL
      AND recording_url IS NULL
      AND started_at > NOW() - INTERVAL '24 hours'
  `);

  for (const record of pendingRecordings.rows) {
    try {
      // Descarga de Asterisk vía SFTP o HTTP (carpeta /var/spool/asterisk/monitor)
      const fileBuffer = await downloadFromAsterisk(record.recording_filename);
      
      // Sube a S3/MinIO
      const s3Key = `recordings/${record.id}/${record.recording_filename}`;
      await s3.putObject({ Bucket: 'crm-files', Key: s3Key, Body: fileBuffer });
      
      // Actualiza URL en BD
      await db.query(
        'UPDATE call_records SET recording_url = $1 WHERE id = $2',
        [`${S3_BASE_URL}/${s3Key}`, record.id]
      );
    } catch (err) {
      logger.error('Error syncing recording', { recordId: record.id, err });
    }
  }
});
```

#### Componente React — Botón Click-to-Call

```jsx
// src/components/ui/ClickToCallButton.jsx
function ClickToCallButton({ contactPhone, contactId, opportunityId }) {
  const { user } = useAuth();
  const [callState, setCallState] = useState('idle'); // idle | calling | connected | ended

  // Escucha screen pop via WebSocket
  useEffect(() => {
    const unsubscribe = websocket.on('SCREEN_POP', (data) => {
      if (data.contact.id === contactId) setCallState('connected');
    });
    return unsubscribe;
  }, [contactId]);

  const handleCall = async () => {
    setCallState('calling');
    try {
      await api.post('/telephony/click-to-call', {
        destinationNumber: contactPhone,
        contactId,
        opportunityId,
      });
      // El agente verá sonar su teléfono; el estado cambia via WebSocket
    } catch (err) {
      setCallState('idle');
      toast.error('Error al iniciar llamada');
    }
  };

  return (
    <button
      onClick={handleCall}
      disabled={callState === 'calling'}
      className={`btn-call btn-call--${callState}`}
      aria-label={`Llamar a ${contactPhone}`}
    >
      <PhoneIcon />
      {callState === 'idle'   && contactPhone}
      {callState === 'calling' && 'Conectando...'}
      {callState === 'connected' && 'En llamada'}
    </button>
  );
}
```

#### Feature Flag y Variables de Entorno

```bash
# .env — Asterisk (desactivado por defecto)
ASTERISK_ENABLED=false
ASTERISK_AMI_HOST=192.168.1.100
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=crm_user
ASTERISK_AMI_SECRET=secret_seguro
ASTERISK_ARI_URL=http://192.168.1.100:8088
ASTERISK_ARI_USER=ari_user
ASTERISK_ARI_PASSWORD=ari_secret
ASTERISK_RECORDING_SYNC_INTERVAL=300  # segundos entre sincronizaciones
```

#### Requisitos Mínimos del Servidor Asterisk
| Requisito | Valor |
|---|---|
| Versión mínima Asterisk | 13 LTS (recomendado 18 LTS o 20 LTS) |
| Módulos requeridos | `res_ari`, `res_manager`, `app_mixmonitor` (grabaciones), `cdr_custom` |
| Puerto AMI | 5038 TCP (accesible desde servidor CRM) |
| Puerto ARI | 8088 HTTP o 8089 HTTPS |
| Carpeta grabaciones | `/var/spool/asterisk/monitor/` con acceso SFTP/HTTP |
| Dialplan | Variable `CRM_CONTACT_ID` propagada en contexto `from-internal` |

