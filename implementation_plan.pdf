### 4.3 Ejemplo: Service Layer (Oportunidades)

```javascript
// src/modules/opportunities/opportunities.service.js
import { OpportunitiesRepository } from './opportunities.repository.js';
import { automationQueue } from '../../jobs/automation.queue.js';
import { aiQueue } from '../../jobs/ai.queue.js';

export class OpportunitiesService {
  constructor() {
    this.repo = new OpportunitiesRepository();
  }

  async moveStage(opportunityId, newStageId, userId) {
    const opportunity = await this.repo.findById(opportunityId);
    if (!opportunity) throw new NotFoundError('Oportunidad no encontrada');

    const previousStageId = opportunity.stage_id;

    // Registra historial de movimiento
    await this.repo.recordStageChange(opportunityId, previousStageId, newStageId, userId);

    // Actualiza la oportunidad
    const updated = await this.repo.updateStage(opportunityId, newStageId);

    // Dispara automatizaciones de forma asíncrona
    await automationQueue.add('trigger', {
      event: 'stage_changed',
      payload: { opportunityId, previousStageId, newStageId, userId }
    });

    // Solicita sugerencia de IA en background
    await aiQueue.add('generate-suggestion', {
      contextType: 'opportunity',
      contextId: opportunityId,
      userId,
      trigger: 'stage_changed',
      data: { newStageId }
    });

    return updated;
  }
}
```

